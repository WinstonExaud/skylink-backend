# ─── SERVER ───────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── DATABASE ─────────────────────────────────────
# Local LAN PostgreSQL (same server as Node.js)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=skylink_db
DB_USER=skylink_user
DB_PASSWORD=skylink_pass_change_me

# ─── JWT ──────────────────────────────────────────
JWT_SECRET=skylink_super_secret_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=8h

# ─── MIKROTIK ROUTER ──────────────────────────────
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASS=your_mikrotik_password

# ─── CORS ─────────────────────────────────────────
# Comma-separated list of allowed origins
# For captive portal use the router/backend LAN IP
ALLOWED_ORIGINS=http://localhost:5173,http://192.168.88.2:5173,http://192.168.88.1

# ─── RATE LIMITING ────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

# ─── EXPIRY JOB ───────────────────────────────────
# How often the expiry cron runs (cron expression)
# Default: every 1 minute
EXPIRY_CRON=* * * * *

# ─── ADMIN ────────────────────────────────────────
# Default admin created by seed script
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
